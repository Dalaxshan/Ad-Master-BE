<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>New Order Received</title>
  <style>
    body,
    table,
    td,
    a {
      -webkit-text-size-adjust: 100%;
      -ms-text-size-adjust: 100%;
    }

    table,
    td {
      mso-table-lspace: 0pt;
      mso-table-rspace: 0pt;
    }

    img {
      -ms-interpolation-mode: bicubic;
      border: 0;
      height: auto;
      line-height: 100%;
      outline: none;
      text-decoration: none;
    }

    body {
      margin: 0;
      padding: 0;
      width: 100% !important;
      height: 100% !important;
      background-color: #F0EEF7;
    }

    @media screen and (max-width: 600px) {
      .email-container {
        width: 100% !important;
      }

      .stack-cell {
        padding-left: 24px !important;
        padding-right: 24px !important;
      }

      .order-id-tag {
        font-size: 28px !important;
      }
    }
  </style>
</head>

<body style="margin:0; padding:0; background-color:#F0EEF7; font-family: Arial, Helvetica, sans-serif;">

  <!-- Preheader (hidden) -->
  <div style="display:none; max-height:0; overflow:hidden; mso-hide:all;">
    New order #{{orderId}} from #{{name}} is waiting for you.
  </div>

  <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0" style="background-color:#F0EEF7;">
    <tr>
      <td align="center" style="padding: 40px 16px;">

        <table role="presentation" class="email-container" width="600" cellpadding="0" cellspacing="0" border="0"
          style="width:600px; max-width:600px; background-color:#FFFFFF; border-radius:16px; overflow:hidden; box-shadow: 0 1px 3px rgba(20,16,74,0.08);">

          <!-- Logo bar -->
          <tr>
            <td align="center" style="background-color:#FFFFFF; padding: 28px 20px 20px 20px;">
              <img src="https://pub-99e17fed1d7345978ebaceb328549b8f.r2.dev/logo.png" alt="AdMaster" height="36"
                style="display:block; height:80px; width:auto;" />
            </td>
          </tr>

          <!-- Divider -->
          <tr>
            <td style="padding: 0 40px;">
              <div style="border-top: 1px solid #ECE9F5; font-size:0; line-height:0;">&nbsp;</div>
            </td>
          </tr>

          <!-- Headline band -->
          <tr>
            <td align="center" class="stack-cell" style="background-color:#14104A; padding: 36px 40px 32px 40px;">
              <p
                style="margin:0 0 10px 0; font-size:12px; letter-spacing:2.5px; text-transform:uppercase; color:#8B85D6; font-weight:bold; font-family: Arial, Helvetica, sans-serif;">
                New Order
              </p>
              <p class="order-id-tag"
                style="margin:0; font-size:34px; line-height:1.2; color:#FFFFFF; font-weight:bold; font-family: Arial, Helvetica, sans-serif;">
                #{{orderId}}
              </p>
            </td>
          </tr>

          <!-- Body -->
          <tr>
            <td class="stack-cell" style="padding: 36px 40px 8px 40px; font-family: Arial, Helvetica, sans-serif;">
              <p style="margin:0 0 16px 0; font-size:16px; line-height:1.6; color:#1F1B4D;">
                Hi there,
              </p>
              <p style="margin:0 0 24px 0; font-size:15px; line-height:1.6; color:#5B5580;">
                A new order has just come in. Here are the details:
              </p>
            </td>
          </tr>

          <!-- Order detail "ticket" card -->
          <tr>
            <td class="stack-cell" style="padding: 0 40px 8px 40px;">
              <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0"
                style="background-color:#F6F5FC; border: 1px solid #E9E6F7; border-radius: 12px;">
                <tr>
                  <td style="padding: 20px 24px;">
                    <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0">
                      <tr>
                        <td
                          style="font-family: Arial, Helvetica, sans-serif; font-size:13px; color:#8A84B3; padding-bottom:4px;">
                          Order ID</td>
                      </tr>
                      <tr>
                        <td
                          style="font-family: Arial, Helvetica, sans-serif; font-size:16px; color:#1F1B4D; font-weight:bold; padding-bottom:14px;">
                          #{{orderId}}</td>
                      </tr>
                      <tr>
                        <td style="border-top: 1px dashed #D9D4EE; font-size:0; line-height:0; padding-top:14px;">&nbsp;
                        </td>
                      </tr>
                      <tr>
                        <td
                          style="font-family: Arial, Helvetica, sans-serif; font-size:13px; color:#8A84B3; padding-top:14px; padding-bottom:4px;">
                          Placed by</td>
                      </tr>
                      <tr>
                        <td
                          style="font-family: Arial, Helvetica, sans-serif; font-size:16px; color:#1F1B4D; font-weight:bold;">
                          #{{name}}</td>
                      </tr>
                    </table>
                  </td>
                </tr>
              </table>
            </td>
          </tr>

          <!-- CTA -->
          <tr>
            <td align="center" class="stack-cell" style="padding: 32px 40px 40px 40px;">
              <table role="presentation" cellpadding="0" cellspacing="0" border="0">
                <tr>
                  <td align="center" style="border-radius: 8px; background-color:#FF6B4A;">
                    <a href="https://admin.admasterlk.com/dashboard/orders" target="_blank"
                      style="display:inline-block; padding: 14px 36px; font-family: Arial, Helvetica, sans-serif; font-size:15px; font-weight:bold; color:#FFFFFF; text-decoration:none; border-radius:8px;">
                      View Order
                    </a>
                  </td>
                </tr>
              </table>

            </td>
          </tr>

        </table>

        <!-- Footer -->
        <table role="presentation" class="email-container" width="600" cellpadding="0" cellspacing="0" border="0"
          style="width:600px; max-width:600px;">
          <tr>
            <td align="center" style="padding: 24px 20px 0 20px; font-family: Arial, Helvetica, sans-serif;">
              <p style="margin:0; font-size:12px; line-height:1.6; color:#A6A1C7;">
                © 2026 <a href="https://www.admasterlk.com" target="_blank"
                  style="color:#8A84B3; text-decoration:underline;">Admasterlk.com</a>. All rights reserved.
              </p>
            </td>
          </tr>
        </table>

      </td>
    </tr>
  </table>

</body>

</html>